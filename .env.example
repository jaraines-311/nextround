# ============================================================
# NextRound — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ----- Database -----
POSTGRES_USER=nextround
POSTGRES_PASSWORD=nextround_secret
POSTGRES_DB=nextround
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nextround:nextround_secret@localhost:5432/nextround

# ----- App -----
NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# ----- Auth -----
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ----- AI Provider -----
# Supported: openai | anthropic
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ----- Stripe -----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_CREDITS_1000_PRICE_ID=price_...
STRIPE_CREDITS_5000_PRICE_ID=price_...
STRIPE_CREDITS_10000_PRICE_ID=price_...

# ----- AI Credit Costs -----
VOICE_INTERVIEW_CREDIT_COST=50
FEEDBACK_REPORT_CREDIT_COST=100
QUESTION_GENERATION_CREDIT_COST=20
RESUME_ANALYSIS_CREDIT_COST=75
JOB_ANALYSIS_CREDIT_COST=50

# ----- AI Credit Grants -----
FREE_INITIAL_CREDITS=1500
PRO_MONTHLY_CREDITS=5000
PREMIUM_MONTHLY_CREDITS=15000
MAX_CREDIT_MULTIPLIER=2

# ----- Admin / Access -----
ADMIN_EMAIL=admin@nextround.ai
FREE_FOREVER_ACCESS_CODE=nextround_free_forever

# ----- Frontend (public env vars prefixed with NEXT_PUBLIC_) -----
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ----- Sentry (backend) -----
SENTRY_DSN_BACKEND=https://...@sentry.io/...

# ----- Supabase Storage -----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=nextround-resumes
